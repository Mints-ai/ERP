rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Helper function to get the current employee's record
    function getEmployee() {
      return get(/databases/$(database)/documents/employees/$(request.auth.uid)).data;
    }

    // Helper function to check if the user is a manager or above
    function isManagerOrAbove() {
      return getEmployee().role in ['founder', 'system_admin', 'c_suite', 'manager'];
    }

    // Helper: Founder or System Admin only (apex roles)
    function isFounderOrAdmin() {
      return getEmployee().role in ['founder', 'system_admin'];
    }

    // Helper function to check if the user is finance admin
    function isFinanceAdmin() {
      return getEmployee().role in ['founder', 'system_admin', 'c_suite', 'manager'];
    }

    // Employees Collection Rules
    match /employees/{employeeId} {
      allow read: if isAuth();
      allow write: if isAuth() && (request.auth.uid == employeeId || isManagerOrAbove());
    }

    // Leaves Collection Rules
    match /leaves/{leaveId} {
      allow read: if isAuth() && (resource.data.employeeId == request.auth.uid || isManagerOrAbove());
      allow create: if isAuth() && request.resource.data.employeeId == request.auth.uid;
      allow update: if isAuth() && isManagerOrAbove();
      allow delete: if isAuth() && isManagerOrAbove();
    }

    // Leave Balances Collection Rules
    match /leaveBalances/{balanceId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrAbove();
    }

    // Tasks Collection Rules
    match /tasks/{taskId} {
      allow read: if isAuth();
      allow create: if isAuth() && isManagerOrAbove();
      allow update: if isAuth() && (resource.data.assignedTo == request.auth.uid || isManagerOrAbove());
      allow delete: if isAuth() && isManagerOrAbove();
    }

    // Clients Collection Rules
    match /clients/{clientId} {
      allow read: if isAuth() && getEmployee().role != 'intern';
      allow write: if isAuth() && isManagerOrAbove();
    }

    // Invoices Collection Rules
    match /invoices/{invoiceId} {
      allow read: if isAuth() && isFinanceAdmin();
      allow write: if isAuth() && isFinanceAdmin();
    }

    // Expenses Collection Rules
    match /expenses/{expenseId} {
      allow read: if isAuth() && (resource.data.submittedBy == request.auth.uid || isManagerOrAbove());
      allow create: if isAuth() && request.resource.data.submittedBy == request.auth.uid;
      allow update: if isAuth() && isManagerOrAbove();
      allow delete: if isAuth() && isManagerOrAbove();
    }

    // Attendance Collection Rules
    match /attendance/{attendanceId} {
      allow get: if isAuth() && (attendanceId[0:request.auth.uid.size()] == request.auth.uid || isManagerOrAbove());
      allow list: if isAuth() && isManagerOrAbove();
      allow list: if isAuth() && resource.data.uid == request.auth.uid;
      allow write: if isAuth() && (attendanceId[0:request.auth.uid.size()] == request.auth.uid || isManagerOrAbove());
    }

    // Attendance Corrections Collection Rules
    match /attendanceCorrections/{requestId} {
      allow get: if isAuth() && (resource.data.uid == request.auth.uid || isManagerOrAbove());
      allow list: if isAuth() && isManagerOrAbove();
      allow list: if isAuth() && resource.data.uid == request.auth.uid;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuth() && isManagerOrAbove();
    }

    // Status Reports Collection Rules
    match /statusReports/{reportId} {
      allow get: if isAuth() && (resource.data.uid == request.auth.uid || isManagerOrAbove());
      allow list: if isAuth() && isManagerOrAbove();
      allow list: if isAuth() && resource.data.uid == request.auth.uid;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuth() && isManagerOrAbove();
    }

    // Shoutouts Collection Rules
    match /shoutouts/{shoutoutId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAuth() && (resource.data.authorId == request.auth.uid || isManagerOrAbove());
    }

    // Projects Collection Rules
    match /projects/{projectId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrAbove();
    }

    // Settings Collection Rules
    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrAbove();
    }

    // CRM Leads Collection Rules
    match /leads/{leadId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAuth() && isManagerOrAbove();

      match /emails/{emailId} {
        allow read, write: if isAuth();
      }
    }

    // Audit Log Collection Rules
    // SECURITY: auditLog is append-only. Tampering (update/delete) is permanently denied.
    // Only Founders and System Admins may read sensitive security events.
    match /auditLog/{logId} {
      allow read:   if isAuth() && isFounderOrAdmin();
      allow create: if isAuth();
      allow update: if false; // Tamper-proof: audit records are immutable
      allow delete: if false; // Tamper-proof: audit records cannot be purged
    }

    // PDF Vault Collection Rules (stores metadata for uploaded documents)
    match /pdfVaults/{vaultId} {
      allow read:   if isAuth() && isFinanceAdmin();
      allow create: if isAuth() && isManagerOrAbove();
      allow update: if false;
      allow delete: if isAuth() && isFounderOrAdmin();
    }

    // Security Events Collection Rules (blocked logins, de-duplication events)
    match /securityEvents/{eventId} {
      allow read:   if isAuth() && isFounderOrAdmin();
      allow create: if isAuth(); // Written by server-side auth hooks
      allow update: if false;
      allow delete: if false;
    }

    // Internal Mails Collection Rules
    match /internal_mails/{mailId} {
      allow read: if isAuth() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuth() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }

    // Chat Channels Collection Rules
    match /chatChannels/{channelId} {
      allow read: if isAuth() && (resource.data.type in ['global', 'department'] || request.auth.uid in resource.data.members);
      allow create: if isAuth();
      allow update, delete: if isAuth() && (resource.data.type in ['global', 'department'] || request.auth.uid in resource.data.members || isManagerOrAbove());
    }

    // Chat Messages Collection Rules
    match /messages/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && (resource.data.userId == request.auth.uid || isManagerOrAbove());
    }

    // Announcements Collection Rules
    match /announcements/{announcementId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrAbove();
    }

    // OKRs Collection Rules
    match /okrs/{okrId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrAbove();
    }

     // Assets Collection Rules
    match /assets/{assetId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrAbove();
    }

    // Asset Maintenance Logs Collection Rules
    match /assetMaintenanceLogs/{logId} {
      allow read: if isAuth();
      allow write: if isAuth() && isManagerOrAbove();
    }

    // Notifications Collection Rules
    match /notifications/{notificationId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || resource.data.userId == 'global' || isManagerOrAbove());
      allow write: if isAuth();
    }

    // Chat Typing Presence Collection Rules
    match /chatTyping/{typingId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
  }
}
