rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check authentication
    function isAuth() {
      return request.auth != null;
    }
    
    // Profile Photos: Anyone logged in can read. Only the user can upload their own.
    match /profile-photos/{userId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Resumes: Anyone logged in can read/write resumes for ATS
    match /resumes/{allPaths=**} {
      allow read, write: if isAuth();
    }

    // Default fallback: Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
